# Shortly Environment Configuration
# Copy this file to .env and update with your actual values

# Base URL for generated short links
# For EC2: use your EC2 public IP or domain
SHORTLY_BASE_URL=http://localhost:8080

# CORS allowed origins (comma-separated)
# For EC2: use your EC2 public IP or domain
SHORTLY_CORS_ALLOWED_ORIGINS=http://localhost:8082,http://localhost:4200

# Redis connection (usually leave as defaults for Docker Compose)
REDIS_HOST=redis
REDIS_PORT=6379
